# Backend API Configuration
# Copy this file to .env and update with your backend server details

# Backend Base URL
# Update the IP address to match your friend's backend server
VITE_API_BASE_URL=http://10.140.8.28:8089

# Examples:
# Local backend: VITE_API_BASE_URL=http://localhost:8089
# Remote backend: VITE_API_BASE_URL=http://192.168.1.100:8089
# Production: VITE_API_BASE_URL=https://api.yourcompany.com

